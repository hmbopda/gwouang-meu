# =============================================================
# GWANG MEU — Variables d'environnement
# Copier ce fichier : cp .env.example .env
# Ne jamais committer le fichier .env
# =============================================================

# ----- Docker local -----
DB_PASSWORD=gwangmeu_secret
SUPABASE_DB_URL=jdbc:postgresql://localhost:5432/gwangmeu_dev

# ----- Supabase -----
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=
SUPABASE_JWT_ISSUER_URI=https://xxx.supabase.co/auth/v1
SUPABASE_JWKS_URI=https://xxx.supabase.co/auth/v1/.well-known/jwks.json

# ----- JWT (min 32 chars) -----
# Générer : openssl rand -hex 32
JWT_SECRET=change_me_in_production_at_least_32_chars

# ----- Claude / Anthropic -----
ANTHROPIC_API_KEY=

# ----- Neo4j AuraDB -----
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=gwangmeu_neo4j

# ----- Redis (Upstash) -----
REDIS_URL=redis://localhost:6379

# ----- LiveKit Cloud -----
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_WS_URL=wss://xxx.livekit.cloud

# ----- Mapbox -----
MAPBOX_ACCESS_TOKEN=

# ----- Meilisearch -----
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=gwangmeu_meili

# ----- Cloudflare R2 -----
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=gwangmeu-media
R2_ACCOUNT_ID=
R2_PUBLIC_URL=https://media.gwouangmeu.com

# ----- Mail (moteur unique : Resend) -----
# Voir docs/EMAIL_SETUP.md pour la mise en place (domaine, DNS, Supabase SMTP).
# MAIL_FROM doit etre une adresse d'un domaine VERIFIE dans Resend
# (ex. noreply@gwouangmeu.com). En test : onboarding@resend.dev (livre seulement
# vers l'adresse du proprietaire du compte Resend).
MAIL_PROVIDER=smtp              # 'smtp' (defaut) ou 'resend-api' (API HTTP, robuste Cloud Run)
MAIL_HOST=smtp.resend.com
MAIL_PORT=465
MAIL_USERNAME=resend
MAIL_PASSWORD=                  # = cle API Resend (re_...)
MAIL_FROM=noreply@gwouangmeu.com
RESEND_API_KEY=                 # requis si MAIL_PROVIDER=resend-api

# ----- Firebase / Sentry -----
FIREBASE_SERVICE_ACCOUNT_JSON=
SENTRY_DSN_JAVA=

# ----- URLs -----
APP_URL=https://app.gwouangmeu.com
LANDING_URL=https://gwouangmeu.com
