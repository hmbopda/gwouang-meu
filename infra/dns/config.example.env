# ── Cloudflare DNS & sécurité — configuration ───────────────────────────────
# Copie ce fichier en `config.env` puis remplis les valeurs.
# config.env est ignoré par git — n'y mets jamais de secret dans un fichier versionné.

# API Token Cloudflare (PAS la Global API Key).
# Cloudflare → My Profile → API Tokens → Create Token.
# Permissions : Zone:Read, DNS:Edit, Zone Settings:Edit, DNSSEC:Edit, Dynamic Redirect:Edit
CF_API_TOKEN="cf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Account ID (Cloudflare → ta zone → barre latérale « Account ID »)
CF_ACCOUNT_ID="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ── Domaines ────────────────────────────────────────────────────────────────
CANONICAL_DOMAIN="gwouangmeu.com"
# Domaines qui redirigent (301) vers le canonique. Vide pour l'instant : tu n'as
# que le .com. Si tu prends plus tard gwouang-meu.com / .org, ajoute-les ici
# (séparés par des espaces) après les avoir ajoutés comme zone Cloudflare.
REDIRECT_DOMAINS=""

# ── Cibles d'infrastructure (adapte à ton compte) ───────────────────────────
VERCEL_APEX_IP="76.76.21.21"
VERCEL_CNAME="cname.vercel-dns.com"

# Cloudflare Pages (app Flutter web) : <projet>.pages.dev
PAGES_TARGET="gwouangmeu-app.pages.dev"

# Railway : CNAME exact affiché par Railway lors de l'ajout d'un custom domain
RAILWAY_API_TARGET="votre-service-prod.up.railway.app"
RAILWAY_STAGING_TARGET="votre-service-staging.up.railway.app"

# ── Email : posture PROTECTRICE par défaut (tu n'envoies pas encore d'emails) ─
# SPF "-all" = personne n'est autorisé à envoyer au nom du domaine → empêche
# l'usurpation. DMARC "p=reject" = les emails frauduleux sont rejetés.
# Quand tu commenceras à envoyer via Resend :
#   SPF_RECORD="v=spf1 include:_spf.resend.com -all"
#   DMARC_RECORD="v=DMARC1; p=quarantine; rua=mailto:dmarc@gwouangmeu.com"
#   RESEND_DKIM_VALUE="<valeur DKIM fournie par Resend>"
SPF_RECORD="v=spf1 -all"
RESEND_DKIM_NAME="resend._domainkey"
RESEND_DKIM_VALUE=""    # vide = ignoré (rien à signer tant que tu n'envoies pas)
DMARC_RECORD="v=DMARC1; p=reject; rua=mailto:dmarc@gwouangmeu.com"
