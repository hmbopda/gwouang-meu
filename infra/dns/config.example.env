# ── Cloudflare DNS — configuration ──────────────────────────────────────────
# Copie ce fichier en `config.env` puis remplis les valeurs.
# config.env est ignoré par git (voir .gitignore) — n'y mets jamais de secret
# dans un fichier versionné.

# API Token Cloudflare (PAS la Global API Key).
# Crée-le : Cloudflare → My Profile → API Tokens → Create Token.
# Permissions : Zone:Read, DNS:Edit, Dynamic Redirect:Edit  (sur toutes tes zones)
CF_API_TOKEN="cf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Account ID (Cloudflare → n'importe quelle zone → barre latérale « Account ID »)
CF_ACCOUNT_ID="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ── Domaines ────────────────────────────────────────────────────────────────
CANONICAL_DOMAIN="gwouang-meu.com"
# Domaines qui redirigent (301) vers le canonique. Séparés par des espaces.
# Retire ceux que tu n'as pas encore ajoutés comme zone Cloudflare.
REDIRECT_DOMAINS="gwouang-meu.fr gwouang-meu.org gwouang-meu.cm"

# ── Cibles d'infrastructure (adapte à ton compte) ───────────────────────────
# Vercel apex (landing) — laisse tel quel sauf indication contraire de Vercel
VERCEL_APEX_IP="76.76.21.21"
VERCEL_CNAME="cname.vercel-dns.com"

# Cloudflare Pages (app Flutter web) : <projet>.pages.dev
PAGES_TARGET="gwouang-meu-app.pages.dev"

# Railway : CNAME exact affiché par Railway quand tu ajoutes un custom domain
RAILWAY_API_TARGET="votre-service-prod.up.railway.app"
RAILWAY_STAGING_TARGET="votre-service-staging.up.railway.app"

# ── Email (envoi via Resend — colle les vrais enregistrements) ──────────────
SPF_RECORD="v=spf1 include:_spf.resend.com ~all"
RESEND_DKIM_NAME="resend._domainkey"
RESEND_DKIM_VALUE="colle_ici_la_valeur_dkim_fournie_par_resend"
DMARC_RECORD="v=DMARC1; p=quarantine; rua=mailto:dmarc@gwouang-meu.com"
